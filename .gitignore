# Logs
logs/
log_archive/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Browser cache from Puppeteer
puppeteer-profile/

# Claude Code context
.claude/

# Temporary files
*.tmp
*.swp
*.swo
*~

# PID files
*.pid
*.pid.lock
*.seed

# Python bytecode
__pycache__/
*.pyc
*.pyo

# ML model binaries (too large for git; separate project-scope storage)
# Added after 45MB yolo11m-seg.pt from the discontinued halal-video project
# appeared untracked in the working tree.
*.pt
*.onnx
*.safetensors

# Lock files
/tmp/stream_*.lock

# Backup files
*.bck
*.old
*.bak
*.backup

# Video/media test files
*.mp4
*.ts
*.m3u8

# Cookies / credentials (sensitive)
# 2026-04-19: generalized to *credentials*.json so any current OR future
# provider credential file is blocked by default. Previously we maintained
# per-provider exceptions and missed channels/ayyadonline_credentials.json,
# which resulted in a 56-day public-repo exposure (CSO finding 2026-04-19,
# fixed same day).
channels/*credentials*.json
!channels/*.example.json
channels/provider_credentials.json
channels/seenshow_credentials.json
channels/ayyadonline_credentials.json
channels/.seenshow_cookies.json
channels/*cookies.txt
playlists/*.m3u

# Auto-generated runtime cache (rebuilt by provider_sync every 30 min)
channels/provider_catalog.json
channels/*_catalog.json

# Operator bot runtime state (Telegram getUpdates offset)
channels/operator_bot/update_offset

# Brain loop runtime state — lock, live state JSON, per-wake raw logs.
# Never commit: state.json changes every 30 min, raw/ is an LLM transcript
# dump that may contain sensitive system state, wake.lock is a flock handle.
channels/brain/wake.lock
channels/brain/state.json
channels/brain/raw/

# Vendored external dependency (separate repo/workflow)
channels/bgutil-pot-node/

# GPG keys
*.gpg

# OS files
.DS_Store
Thumbs.db

# Node.js
node_modules/
.npm
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
